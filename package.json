{
  "name": "ghostreview",
  "displayName": "GhostReview",
  "description": "AI code review that sounds like a senior engineer, not a linter. Reviews your git diff before your senior does.",
  "version": "0.1.4",
  "publisher": "ghostReview2026",
  "icon": "resources/icon.png",
  "homepage": "https://ghost-review-kappa.vercel.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/kshitij33/ghost-review-extension"
  },
  "galleryBanner": {
    "color": "#0a0a08",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Linters",
    "Education"
  ],
  "keywords": [
    "code review",
    "ai",
    "git",
    "diff",
    "groq",
    "llama"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ghostreview.startReview",
        "title": "GhostReview: Review My Changes"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ghostreview-sidebar",
          "title": "GhostReview",
          "icon": "resources/ghost.svg"
        }
      ]
    },
    "views": {
      "ghostreview-sidebar": [
        {
          "id": "ghostreview-panel",
          "type": "webview",
          "name": "GhostReview"
        }
      ]
    },
    "configuration": {
      "title": "GhostReview",
      "properties": {
        "ghostreview.groqApiKey": {
          "type": "string",
          "default": "",
          "description": "Your Groq API key. Get one free at console.groq.com"
        },
        "ghostreview.apiToken": {
          "type": "string",
          "default": "",
          "description": "Your GhostReview API token from the dashboard. Get it at https://ghost-review-dashboard.vercel.app/dashboard/settings"
        },
        "ghostreview.defaultPersona": {
          "type": "string",
          "default": "brutal",
          "enum": [
            "brutal",
            "velocity",
            "security"
          ],
          "enumDescriptions": [
            "Brutal Architect — tears apart your decisions",
            "Startup Velocity — separates blockers from bikeshedding",
            "Security Paranoid — finds vulnerabilities everywhere"
          ],
          "description": "Default reviewer persona"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.13",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "groq-sdk": "^0.37.0",
    "posthog-node": "^5.21.2"
  }
}
